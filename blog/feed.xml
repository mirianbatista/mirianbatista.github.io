---
layout: null
---
<?xml version="1.0" encoding="utf-8"?>
<feed xmlns="http://www.w3.org/2005/Atom">
  <title>Blog · Mírian Batista</title>
  <link href="{{ site.url }}/blog/"/>
  <link rel="self" href="{{ site.url }}/blog/feed.xml"/>
  <id>{{ site.url }}/blog/</id>
  <author><name>Mírian Batista</name></author>
  <updated>{{ site.posts.first.date | date: "%Y-%m-%dT%H:%M:%SZ" }}</updated>{% for post in site.posts %}
  <entry>
    <title>{{ post.title | xml_escape }}</title>
    <link href="{{ site.url }}{{ post.url }}"/>
    <id>{{ site.url }}{{ post.url }}</id>
    <updated>{{ post.date | date: "%Y-%m-%dT%H:%M:%SZ" }}</updated>
    <category term="{{ post.categoria | xml_escape }}"/>
    <summary>{{ post.summary | xml_escape }}</summary>
  </entry>{% endfor %}
</feed>
